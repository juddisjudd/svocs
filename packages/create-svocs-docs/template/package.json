		"@types/node": "^24",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"katex": "^0.16.7",
		"mdsvex": "^0.12.7",
		"mermaid": "^11.16.0",
