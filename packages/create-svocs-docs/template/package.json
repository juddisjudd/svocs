{
	"name": "__PACKAGE_NAME__",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/search/postbuild.mjs && node scripts/og/generate.mjs",
